#!/usr/bin/env python3
"""
Static server for laptop dev.

Three dev-time conveniences over `python -m http.server`:
  1. no-store headers so updated assets aren't cached
  2. rewrites `import ... from './foo.js'` (or with .css imports) to append a per-process
     ?v=<startup-stamp> so module-graph URLs change each restart — required because
     Chromium caches modules by URL even when HTTP cache is bypassed.
  3. mirrors the Rust server's hls.js marker injection for non-webOS laptop browsers.
"""

from http.server import SimpleHTTPRequestHandler, HTTPServer
import os, re, sys, time

VERSION = str(int(time.time()))
IMPORT_RE = re.compile(rb"""(import\s+(?:[^'"]*?\s+from\s+)?|\bimport\s*\(\s*)(['"])(\.\.?/[^'"]+?\.(?:js|mjs))(['"])""")
PLAYER_BUNDLE_MARKER = b'<!--PLAYER_BUNDLE_MARKER-->'

def add_version(match):
    head, q, path, qq = match.group(1), match.group(2), match.group(3), match.group(4)
    sep = b'&' if b'?' in path else b'?'
    return head + q + path + sep + b'v=' + VERSION.encode() + qq

def player_bundle_for_user_agent(user_agent):
    ua = user_agent.lower()
    if 'web0s' in ua or 'webos' in ua:
        return b''
    return b'<script src="lib/hls.min.js?v=' + VERSION.encode() + b'"></script>'

class DevHandler(SimpleHTTPRequestHandler):
    def end_headers(self):
        self.send_header('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0')
        self.send_header('Pragma', 'no-cache')
        self.send_header('Expires', '0')
        super().end_headers()

    def do_GET(self):
        # Strip any ?v=… so we can read the file on disk.
        path = self.path.split('?', 1)[0]
        if path in ('/', '/index.html'):
            fs_path = self.translate_path('/index.html')
            if not os.path.isfile(fs_path):
                return super().do_GET()
            with open(fs_path, 'rb') as f:
                data = f.read()
            user_agent = self.headers.get('User-Agent', '')
            rewritten = data.replace(PLAYER_BUNDLE_MARKER, player_bundle_for_user_agent(user_agent))
            self.send_response(200)
            self.send_header('Content-Type', 'text/html; charset=utf-8')
            self.send_header('Content-Length', str(len(rewritten)))
            self.end_headers()
            self.wfile.write(rewritten)
            return
        if not path.endswith(('.js', '.mjs')):
            return super().do_GET()
        fs_path = self.translate_path(path)
        if not os.path.isfile(fs_path):
            return super().do_GET()
        with open(fs_path, 'rb') as f:
            data = f.read()
        rewritten = IMPORT_RE.sub(add_version, data)
        self.send_response(200)
        self.send_header('Content-Type', 'text/javascript; charset=utf-8')
        self.send_header('Content-Length', str(len(rewritten)))
        self.end_headers()
        self.wfile.write(rewritten)

port = int(os.environ.get('PORT', '8000'))
root = os.path.join(os.path.dirname(os.path.abspath(__file__)), '..', 'app')
os.chdir(root)
print(f'Serving {root} on http://localhost:{port}  (no-cache, version={VERSION})')
HTTPServer(('0.0.0.0', port), DevHandler).serve_forever()
